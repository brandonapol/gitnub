{
  "name": "cursed-ci",
  "version": "1.0.0",
  "description": "A multi-stage, matrix-validated, artifact-consolidated CI/CD pipeline for Hello World",
  "scripts": {
    "build": "node build.js",
    "lint": "node lint.js",
    "typecheck": "node typecheck.js",
    "bundle": "webpack --config webpack.config.js",
    "prebuild": "npm run lint && npm run typecheck",
    "postbuild": "npm run bundle",
    "test": "node validate.js",
    "format": "prettier --check .",
    "analyze": "node analyze.js"
  },
  "dependencies": {
    "is-odd": "^3.0.1",
    "is-even": "^1.0.0",
    "is-number": "^7.0.0",
    "left-pad": "^1.3.0",
    "express": "^4.18.2",
    "lodash": "^4.17.21",
    "moment": "^2.29.4",
    "axios": "^1.6.0",
    "chalk": "^4.1.2",
    "commander": "^11.1.0",
    "debug": "^4.3.4",
    "dotenv": "^16.3.1",
    "uuid": "^9.0.0",
    "winston": "^3.11.0",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "bcrypt": "^5.1.1",
    "mongoose": "^8.0.0",
    "sequelize": "^6.35.0",
    "pg": "^8.11.3",
    "redis": "^4.6.10",
    "socket.io": "^4.7.2",
    "rxjs": "^7.8.1",
    "jquery": "^3.7.1"
  },
  "devDependencies": {
    "webpack": "^5.89.0",
    "webpack-cli": "^5.1.4",
    "html-webpack-plugin": "^5.5.3",
    "css-loader": "^6.8.1",
    "style-loader": "^3.3.3",
    "babel-loader": "^9.1.3",
    "@babel/core": "^7.23.0",
    "@babel/preset-env": "^7.23.0",
    "@babel/preset-typescript": "^7.23.0",
    "typescript": "^5.2.2",
    "ts-loader": "^9.5.0",
    "eslint": "^8.52.0",
    "prettier": "^3.0.3",
    "jest": "^29.7.0",
    "@types/node": "^20.8.0",
    "nodemon": "^3.0.1",
    "concurrently": "^8.2.1",
    "rimraf": "^5.0.5",
    "cross-env": "^7.0.3",
    "husky": "^8.0.3",
    "lint-staged": "^15.0.2"
  },
  "license": "MIT"
